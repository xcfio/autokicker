{
    "name": "backend",
    "type": "commonjs",
    "author": "xcfio",
    "license": "Proprietary",
    "scripts": {
        "build": "node --experimental-strip-types build.cts",
        "dev": "tsx watch --include src/**/* --no-warnings --env-file-if-exists=.env src/index.ts",
        "docker:build": "docker build --tag api .",
        "docker:start": "docker run --detach --rm --publish 7200:7200 api",
        "fmt": "prettier --config=.prettierrc --write src",
        "fmt:test": "prettier --config=.prettierrc --check src",
        "gen": "drizzle-kit generate",
        "start": "node --env-file-if-exists=.env out/index.js",
        "test": "tsc --noEmit"
    },
    "dependencies": {
        "@fastify/auth": "^5.0.4",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/jwt": "^10.1.0",
        "@fastify/oauth2": "^8.2.0",
        "@fastify/rate-limit": "^11.0.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/type-provider-typebox": "^6.1.0",
        "@repo/database": "workspace:*",
        "@repo/schema": "workspace:*",
        "@repo/utils": "workspace:*",
        "@scalar/fastify-api-reference": "^1.60.0",
        "@socket.io/admin-ui": "^0.5.1",
        "discord-api-types": "^0.38.49",
        "drizzle-orm": "1.0.0-rc.4",
        "fastify": "^5.8.5",
        "fastify-utils": "^0.0.2",
        "postgres": "^3.4.9",
        "snowtransfer": "^0.17.7",
        "socket.io": "^4.8.3",
        "typebox": "^1.2.19"
    },
    "devDependencies": {
        "@types/node": "^26.1.0",
        "rolldown": "1.1.2"
    }
}
