        "drizzle-kit": "^0.31.8",
        "drizzle-orm": "^0.45.1",
        "fastify": "^5.8.5",
        "google-auth-library": "^10.5.0",
        "google-spreadsheet": "^5.0.2",
        "lodash": "^4.17.23",
        "lru-cache": "^11.3.5",
        "postgres": "^3.4.8",
        "ttt-ts": "^0.0.4",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@types/lodash": "^4.17.23",
        "@types/node": "^25.6.0"
    }
