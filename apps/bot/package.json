{
    "name": "bot",
    "type": "commonjs",
    "author": "xcfio",
    "license": "MIT",
    "scripts": {
        "build": "node --experimental-strip-types build.cts",
        "dev": "tsx watch --include src/**/* --no-warnings --env-file-if-exists=.env src/index.ts",
        "docker:build": "docker build --tag bot .",
        "docker:start": "docker run --detach --env-file=.env --rm --publish 7200:7200 bot",
        "fmt": "prettier --config=.prettierrc --write src",
        "fmt:test": "prettier --config=.prettierrc --check src",
        "gen": "drizzle-kit generate",
        "start": "node --env-file-if-exists=.env out/index.js",
        "test": "tsc --noEmit"
    },
    "dependencies": {
        "@repo/database": "workspace:*",
        "@repo/schema": "workspace:*",
        "@repo/utils": "workspace:*",
        "colorette": "^2.0.20",
        "coolcake": "^0.0.5",
        "discord.js": "^14.27.0",
        "drizzle-orm": "1.0.0-rc.4",
        "fastify": "^5.10.0",
        "node-cron": "^4.6.0",
        "postgres": "^3.4.9",
        "typebox": "^1.3.6"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "rolldown": "1.1.5"
    }
}
