{
    "name": "bot",
    "version": "0.0.1",
    "type": "commonjs",
    "author": "xcfio",
    "license": "UNLICENSED",
    "scripts": {
        "build": "rolldown -c",
        "db": "drizzle-kit studio --port=4000",
        "dev": "tsx watch --include src/**/* --no-warnings --env-file-if-exists=.env src/index.ts",
        "docker:build": "docker build --tag api .",
        "docker:start": "docker run --detach --rm --publish 7200:7200 api",
        "fmt": "prettier --config=.prettierrc --write src",
        "fmt:test": "prettier --config=.prettierrc --check src",
        "gen": "drizzle-kit generate",
        "start": "tsx --env-file-if-exists=.env src/index.ts",
        "test": "tsc --noEmit"
    },
    "dependencies": {
        "canvacord": "^6.0.4",
        "colorette": "^2.0.20",
        "coolcake": "^0.0.5",
        "coolice": "^0.0.2",
        "discord.js": "^14.26.3",
        "drizzle-kit": "^0.31.8",
        "drizzle-orm": "^1.0.0-rc.2",
        "fastify": "^5.8.5",
        "google-auth-library": "^10.5.0",
        "google-spreadsheet": "^5.0.2",
        "lodash": "^4.17.23",
        "lru-cache": "^11.3.6",
        "postgres": "^3.4.8",
        "ttt-ts": "^0.0.4",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@types/lodash": "^4.17.23",
        "@types/node": "^25.6.0"
    }
}
