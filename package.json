{
    "name": "autokicker",
    "author": "Omar Faruk (Aka. xcfio)",
    "homepage": "https://github.com/xcfio/autokicker#readme",
    "license": "Proprietary",
    "scripts": {
        "build": "turbo run build",
        "clean": "powershell -Command \"Get-ChildItem -Path . -Filter node_modules -Recurse -Directory | Remove-Item -Recurse -Force\"",
        "dev": "turbo watch dev",
        "fmt": "prettier --config=.prettierrc --write .",
        "fmt:test": "prettier --config=.prettierrc --check src",
        "lint": "oxlint .",
        "lint:fix": "oxlint . --fix",
        "preinstall": "npx only-allow pnpm",
        "start": "turbo run start",
        "studio": "turbo run studio",
        "test": "turbo run test"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/xcfio/autokicker"
    },
    "bugs": {
        "url": "https://github.com/xcfio/autokicker/issues",
        "email": "xcfio@proton.me"
    },
    "devDependencies": {
        "@commitlint/config-conventional": "^21.0.2",
        "@commitlint/format": "^21.0.1",
        "@commitlint/types": "^21.0.1",
        "commitlint": "^21.0.2",
        "oxlint": "^1.70.0",
        "oxlint-plugin-eslint": "^1.70.0",
        "oxlint-tsgolint": "^0.23.0",
        "prettier": "^3.8.4",
        "turbo": "^2.9.18",
        "typescript": "6.0.3"
    },
    "packageManager": "pnpm@11.8.0",
    "engines": {
        "node": ">=26.1"
    },
    "dependencies": {
        "lefthook": "^2.1.9"
    }
}
