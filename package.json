{
    "name": "autokicker",
    "author": "Omar Faruk (Aka. xcfio)",
    "homepage": "https://github.com/xcfio/diploma-bazar#readme",
    "license": "MIT",
    "scripts": {
        "build": "turbo run build",
        "clean": "powershell -Command \"Get-ChildItem -Path . -Filter node_modules -Recurse -Directory | Remove-Item -Recurse -Force\"",
        "dev": "turbo run dev",
        "fmt": "prettier --config=.prettierrc --write .",
        "lint": "node --experimental-strip-types --no-warnings ./node_modules/eslint/bin/eslint.js --flag unstable_native_nodejs_ts_config --config eslint.config.ts",
        "preinstall": "npx only-allow pnpm",
        "test": "turbo run test"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/xcfio/diploma-bazar"
    },
    "bugs": {
        "url": "https://github.com/xcfio/diploma-bazar/issues",
        "email": "xcfio@proton.me"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "lefthook": "^2.1.6",
        "prettier": "^3.8.3",
        "turbo": "^2.9.9",
        "typescript": "6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "packageManager": "pnpm@10.33.2",
    "engines": {
        "node": ">=24"
    }
}
